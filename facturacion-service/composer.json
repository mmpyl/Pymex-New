{
  "name": "pymex/facturacion-service",
  "description": "Servicio de facturación electrónica SUNAT Perú",
  "type": "project",
  "require": {
    "php": "^8.2",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "slim/http": "^1.3",
    "greenter/greenter": "^6.0",
    "greenter/xmldsig": "^5.0",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.5",
    "respect/validation": "^2.3",
    "firebase/php-jwt": "^6.10"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.8"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public",
    "test": "phpunit",
    "lint": "phpcs src/"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
